# ── Database ──
DATABASE_URL=postgresql://user:password@host:5432/insurance_analyzer

# ── Security ──
JWT_SECRET=your-random-64-char-secret-here
ENCRYPTION_KEY=optional-separate-encryption-key

# ── App URL (your Railway public URL) ──
APP_URL=https://your-app.up.railway.app

# ── Google OAuth (for login AND Gmail) ──
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GMAIL_CLIENT_ID=same-as-google-client-id
GMAIL_CLIENT_SECRET=same-as-google-client-secret

# ── Client-side Google OAuth ──
VITE_GOOGLE_CLIENT_ID=same-as-google-client-id

# ── LLM Provider ──
# Gemini (default):
LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=your-gemini-api-key
LLM_MODEL=gemini-2.5-flash
LLM_SUPPORTS_FILE_URL=true

# OpenAI alternative:
# LLM_API_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-openai-key
# LLM_MODEL=gpt-4o
# LLM_SUPPORTS_FILE_URL=false

# OpenRouter alternative:
# LLM_API_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-your-openrouter-key
# LLM_MODEL=google/gemini-2.5-flash
# LLM_SUPPORTS_FILE_URL=false

# ── Storage ──
STORAGE_PATH=/data/uploads

# ── Admin ──
ADMIN_EMAIL=your@email.com
